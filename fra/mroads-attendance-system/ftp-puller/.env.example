# FTP Puller Configuration Example
# Copy this file to .env and update the values

# FTP Configuration
FTP_HOST=172.16.2.64
FTP_PORT=2121
FTP_USERNAME=admin
FTP_PASSWORD=admin

# Remote directory to monitor
FTP_REMOTE_DIR=/Picture/Face Detection/

# Backend API Configuration
#BACKEND_API_URL=https://dev-fra.mroads.com
BACKEND_API_URL=http://127.0.0.1:9090
LOCAL_BACKEND_URL=http://127.0.0.1:8000
# Polling interval in milliseconds (30000 = 30 seconds)
POLL_INTERVAL=30000

# Maximum number of newest files to process per polling cycle
MAX_FILES_TO_PROCESS=2

# Local directory to store processed files tracking
PROCESSED_FILES_DIR=./processed

# WebSocket Configuration
WS_PORT=3000
